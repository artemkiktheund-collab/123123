<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>VanillaSMP Test Checkout</title>
  <style>
    body { background:#0a0a0f; color:#e8e8e8; font-family: monospace; display:grid; place-items:center; min-height:100vh; }
    .box { border:4px solid #7b2fff; padding:28px; max-width:520px; box-shadow:0 0 25px #7b2fff; }
    button { padding:14px 20px; font-weight:900; cursor:pointer; background:#ffd700; border:0; }
    pre { white-space:pre-wrap; color:#00ff88; }
  </style>
</head>
<body>
  <div class="box">
    <h1>TEST CHECKOUT</h1>
    <p>This imitates successful payment. Use only for testing RCON issuing.</p>
    <pre id="info">Loading...</pre>
    <button id="pay">TEST PAY & ISSUE</button>
  </div>

  <script>
    const params = new URLSearchParams(location.search);
    const order = params.get("order");
    const info = document.getElementById("info");

    async function load() {
      const res = await fetch("/api/order/" + order);
      const data = await res.json();
      info.textContent = JSON.stringify(data, null, 2);
    }

    document.getElementById("pay").onclick = async () => {
      const res = await fetch("/api/test-pay/" + order, { method: "POST" });
      const data = await res.json();
      info.textContent = JSON.stringify(data, null, 2);
    };

    load();
  </script>
</body>
</html>
